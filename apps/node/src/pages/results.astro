---
import Base from "../layouts/Base.astro";

type Deck = { id: string; name: string; format: string };
type Tournament = { id: string; deckId: string; name: string; playedAt: string; endedAt?: string; category?: string; format?: string; placement?: string };
type Match = { id: string; tournamentId?: string; deckId: string; playedAt: string; eventName?: string; round?: number; opponentArchetype?: string; result: "win" | "loss" | "draw"; games?: Array<{ result: "win" | "loss" | "draw"; wentFirst?: boolean }> };

async function pluginData(route: string) {
	const response = await fetch(new URL(`/_emdash/api/plugins/pokemon-decklists/${route}`, Astro.url.origin));
	if (!response.ok) return {};
	const body = await response.json();
	return body.data ?? body;
}

const [deckData, tournamentData, matchData] = await Promise.all([pluginData("decks"), pluginData("tournaments"), pluginData("matches")]);
const decks: Deck[] = deckData.items ?? [];
const tournaments: Tournament[] = tournamentData.items ?? [];
const allMatches: Match[] = matchData.items ?? [];
const deckId = Astro.url.searchParams.get("deckId") ?? "";
const format = Astro.url.searchParams.get("format") ?? "";
const from = Astro.url.searchParams.get("from") ?? "";
const to = Astro.url.searchParams.get("to") ?? "";
const started = Astro.url.searchParams.get("started") ?? "";
const allowedTournamentIds = new Set(tournaments.filter((tournament) => !format || tournament.format === format).map((tournament) => tournament.id));
const matches = allMatches.filter((match) => (!deckId || match.deckId === deckId) && (!from || match.playedAt >= from) && (!to || match.playedAt <= to) && (!format || (!!match.tournamentId && allowedTournamentIds.has(match.tournamentId))) && (!started || match.games?.some((game) => started === "first" ? game.wentFirst === true : game.wentFirst === false)));
const wins = matches.filter((match) => match.result === "win").length;
const losses = matches.filter((match) => match.result === "loss").length;
const draws = matches.length - wins - losses;
const matchupMap = new Map<string, { wins: number; losses: number; draws: number; total: number }>();
for (const match of matches) {
	const key = match.opponentArchetype || "Sin identificar";
	const item = matchupMap.get(key) ?? { wins: 0, losses: 0, draws: 0, total: 0 };
	item.total++; item[match.result === "win" ? "wins" : match.result === "loss" ? "losses" : "draws"]++;
	matchupMap.set(key, item);
}
const matchups = [...matchupMap.entries()].sort((a, b) => b[1].total - a[1].total);
const deckNames = new Map(decks.map((deck) => [deck.id, deck.name]));
---

<Base title="Resultados y matchups" description="Torneos, rondas y estadísticas de Pokémon TCG.">
	<section class="results-page">
		<header class="results-hero"><p>RENDIMIENTO COMPETITIVO</p><h1>Torneos y matchups</h1><span>Resultados públicos registrados desde los decklists del blog.</span></header>
		<form class="filters" method="get">
			<label>Decklist<select name="deckId"><option value="">Todas</option>{decks.map((deck) => <option value={deck.id} selected={deck.id === deckId}>{deck.name}</option>)}</select></label>
			<label>Formato<select name="format"><option value="">Todos</option>{["standard","expanded","glc","custom"].map((item) => <option value={item} selected={item === format}>{item.toUpperCase()}</option>)}</select></label>
			<label>Desde<input type="date" name="from" value={from} /></label><label>Hasta<input type="date" name="to" value={to} /></label>
			<label>Inicio<select name="started"><option value="">Cualquiera</option><option value="first" selected={started === "first"}>Comenzó el jugador</option><option value="second" selected={started === "second"}>Comenzó el rival</option></select></label>
			<button type="submit">Aplicar filtros</button><a href="/results">Limpiar</a>
		</form>
		<div class="stats"><article><strong>{matches.length}</strong><span>rondas</span></article><article><strong>{wins}</strong><span>victorias</span></article><article><strong>{losses}</strong><span>derrotas</span></article><article><strong>{draws}</strong><span>empates</span></article><article><strong>{matches.length ? Math.round(wins / matches.length * 1000) / 10 : 0}%</strong><span>win rate</span></article></div>
		<div class="grid">
			<section><h2>Matchups</h2>{matchups.length ? <div class="table-wrap"><table><thead><tr><th>Arquetipo rival</th><th>Registro</th><th>Win rate</th></tr></thead><tbody>{matchups.map(([name,item]) => <tr><th>{name}</th><td>{item.wins}-{item.losses}-{item.draws}</td><td>{Math.round(item.wins / item.total * 1000) / 10}%</td></tr>)}</tbody></table></div> : <p class="empty">No hay rondas para estos filtros.</p>}</section>
			<section><h2>Torneos</h2>{tournaments.length ? <div class="table-wrap"><table><thead><tr><th>Fecha</th><th>Torneo</th><th>Decklist</th><th>Posición</th></tr></thead><tbody>{tournaments.filter((t) => (!deckId || t.deckId === deckId) && (!format || t.format === format) && (!from || t.playedAt >= from) && (!to || t.playedAt <= to)).map((tournament) => <tr><td>{tournament.playedAt}</td><th>{tournament.name}</th><td>{deckNames.get(tournament.deckId) ?? "Decklist"}</td><td>{tournament.placement ?? "—"}</td></tr>)}</tbody></table></div> : <p class="empty">Todavía no hay torneos públicos.</p>}</section>
		</div>
	</section>
</Base>

<style>
	.results-page{width:min(1180px,calc(100% - 2rem));margin:0 auto;padding:clamp(3rem,8vw,7rem) 0}.results-hero{max-width:720px;margin-bottom:2rem}.results-hero p{font-size:.72rem;letter-spacing:.15em;opacity:.6}.results-hero h1{font-size:clamp(2.4rem,7vw,5.5rem);letter-spacing:-.055em;line-height:.95;margin:.5rem 0 1rem}.results-hero span{opacity:.65}.filters{display:grid;grid-template-columns:repeat(5,minmax(120px,1fr));gap:.75rem;padding:1rem;border:1px solid color-mix(in srgb,currentColor 14%,transparent);border-radius:1rem}.filters label{font-size:.7rem;text-transform:uppercase;letter-spacing:.06em}.filters select,.filters input{display:block;width:100%;min-height:42px;margin-top:.4rem;border:1px solid color-mix(in srgb,currentColor 18%,transparent);border-radius:.55rem;padding:.55rem;background:transparent;color:inherit}.filters button,.filters a{min-height:42px;border-radius:999px;padding:.65rem 1rem;display:grid;place-items:center;font:inherit;font-weight:700}.filters button{border:0;background:var(--color-text);color:var(--color-bg);cursor:pointer}.filters a{border:1px solid currentColor;color:inherit;text-decoration:none}.stats{display:grid;grid-template-columns:repeat(5,1fr);gap:.75rem;margin:1rem 0 3rem}.stats article{border:1px solid color-mix(in srgb,currentColor 14%,transparent);border-radius:1rem;padding:1.2rem}.stats strong{display:block;font-size:2rem}.stats span{font-size:.72rem;opacity:.6;text-transform:uppercase}.grid{display:grid;gap:3rem}.grid h2{font-size:1.4rem}.table-wrap{overflow-x:auto;border:1px solid color-mix(in srgb,currentColor 14%,transparent);border-radius:1rem}table{width:100%;min-width:540px;border-collapse:collapse;font-size:.82rem}th,td{text-align:left;padding:.8rem 1rem;border-bottom:1px solid color-mix(in srgb,currentColor 10%,transparent)}thead th{font-size:.68rem;text-transform:uppercase;letter-spacing:.08em;opacity:.6}.empty{opacity:.6}
	@media(max-width:760px){.filters{grid-template-columns:1fr 1fr}.stats{grid-template-columns:repeat(2,1fr)}.results-page{width:min(100% - 1rem,1180px)}}
</style>
